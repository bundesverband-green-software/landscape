ite-carbon-estimation--ecograder","logo":"logos/0e6831bf10613954313aebe0634cb5a74eaad8cb964d77bbe3db0e42def831e8.svg","name":"Ecograder","subcategory":"Website Carbon Estimation","website":"https://ecograder.com/","additional_categories":[{"category":"Website","subcategory":"Website Analysis"}],"description":"Ecograder analyzes websites for environmental impact by evaluating performance, design, development practices, and hosting, offering insights and recommendations to improve digital sustainability. A badge is provided that can be added to the footer of websites.","featured":{"label":"BVGS Approved & Tested","order":1},"maturity":"approved+tested"},{"category":"Website","homepage_url":"https://www.ecoindex.fr/en/","id":"website--website-carbon-estimation--ecoindex","logo":"logos/b97c6013459e15cdc06d7c2e0f12d19957bc89da370f193475eed659ebc6db63.png","name":"EcoIndex","subcategory":"Website Carbon Estimation","website":"https://www.ecoindex.fr/en/","description":"EcoIndex evaluates the environmental impact of web pages by analyzing technical performance, complexity, and resource usage, providing a sustainability score along with actionable recommendations for optimization."},{"category":"Website","homepage_url":"https://kastor.green/","id":"website--website-carbon-estimation--kastor","logo":"logos/f888efb172b7522c565b52c8a7818d4a94011d226d6101b38420c68c11b4a632.svg","name":"Kastor","subcategory":"Website Carbon Estimation","website":"https://kastor.green/","additional_categories":[{"category":"Website","subcategory":"Website Analysis"}],"description":"Kastor estimates the carbon emissions of a website and analyzes it according to eco design and accessibility guidelines."},{"category":"Website","homepage_url":"https://ecoping.earth/","id":"website--website-carbon-estimation--ecoping","logo":"logos/02cfbb331ffdcd8cf8aaa3a250deda98c07531a1778f75d9cc19cc21b81e92b7.svg","name":"EcoPing","subcategory":"Website Carbon Estimation","website":"https://ecoping.earth/","additio